rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidTimestamp() {
      // Requires an updatedAt field of type timestamp
      return request.resource.data.updatedAt is timestamp;
    }
    
    function isRateLimited() {
      // Only allow a write if the existing document was updated more than 2 seconds ago
      return resource == null || request.time > resource.data.updatedAt + duration.value(2, 's');
    }

    function isSafeWrite() {
      return isValidTimestamp() && isRateLimited();
    }

    // --- 1. Users can ONLY read/write their own data ---
    match /users/{userId} {
      // 3. No user can access another user's data
      allow read: if isOwner(userId);
      // 4. All writes must have valid data types
      // 5. Rate limiting pattern using timestamps
      allow write: if isOwner(userId) 
                   && isSafeWrite()
                   && request.resource.data.keys().hasOnly(['displayName', 'email', 'photoURL', 'createdAt', 'updatedAt', 'uid']);

      match /progress/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
                     && isSafeWrite()
                     && request.resource.data.keys().hasOnly(['moduleId', 'completed', 'score', 'startedAt', 'updatedAt'])
                     && request.resource.data.completed is bool;
      }
      
      match /badges/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
                     && isSafeWrite()
                     && request.resource.data.keys().hasOnly(['badgeId', 'earnedAt', 'title', 'description', 'icon', 'updatedAt'])
                     && request.resource.data.badgeId is string;
      }
      
      match /quizScores/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
                     && isSafeWrite()
                     && request.resource.data.keys().hasOnly(['score', 'total', 'topic', 'difficulty', 'createdAt', 'updatedAt'])
                     && request.resource.data.score is number
                     && request.resource.data.total is number
                     && request.resource.data.topic is string;
      }
      
      match /checklist/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
                     && isSafeWrite()
                     && request.resource.data.keys().hasOnly(['itemId', 'checked', 'title', 'updatedAt'])
                     && request.resource.data.checked is bool;
      }
    }

    // --- 2. Leaderboard ---
    match /leaderboard/{docId} {
      allow read: if true; // Anyone can READ
      // Only authenticated users can WRITE, and can only write their own userId
      allow write: if isAuthenticated() 
                   && request.resource.data.userId == request.auth.uid 
                   && isSafeWrite()
                   && request.resource.data.keys().hasOnly(['userId', 'score', 'displayName', 'photoURL', 'rank', 'updatedAt'])
                   && request.resource.data.score is number
                   && request.resource.data.userId is string;
    }
    
    // Default public election data (e.g. static facts)
    match /electionData/{document} {
      allow read: if true;
      allow write: if false;
    }
  }
}
